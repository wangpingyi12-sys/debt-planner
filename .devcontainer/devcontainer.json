{
  "name": "Flutter Dev",
  "image": "cirrusci/flutter:stable",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.flutter",
        "Dart-Code.dart-code",
        "eamodio.gitlens",
        "trae-ai.trae"
      ]
    }
  },
  "forwardPorts": [8080, 5037, 5555],
  "postCreateCommand": "flutter doctor && flutter pub get",
  "remoteUser": "root"
}